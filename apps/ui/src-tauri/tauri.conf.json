{
  "$schema": "../../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Cesante Manager",
  "version": "0.1.1",
  "identifier": "com.cesante.manager",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Cesante Manager",
        "fullscreen": true,
        "resizable": false,
        "decorations": false,
        "maximized": false,
        "width": 1400,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 700,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZFRUQ5Njc3NDcxMUZCMkUKUldRdSt4RkhkNWJ0L3RFanJyZFgyb1QwbHpCcHJOYWdmV2wvWURFaTdWNWc5eE5YMVAvSHNLKzkK",
      "endpoints": [
        "https://github.com/NegrOlivares/anfpes-engine/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
