{
  "name": "anfpes-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo para el motor y aplicaciones ANFPES.",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run typecheck && npm run lint && npm run test",
    "dev": "echo \"Define dev scripts por paquete\"",
    "format": "prettier --write .",
    "lint": "eslint . --ext .ts,.tsx,.js,.cjs,.mjs",
    "prepare": "husky",
    "test": "vitest",
    "test:watch": "vitest watch",
    "typecheck": "tsc -b"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,md}": "prettier --write"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "@vitest/coverage-c8": "^0.33.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
